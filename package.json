{
  "name": "ilt",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    },
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "include": [
      "/",
      "/about",
      "/courses",
      "/courses/digital-marketing-course-kochi",
      "/placements",
      "/events",
      "/events/podcast-training-2025",
      "/events/ilt-onam-celebrations-2025",
      "/hire-digital-marketers-in-india",
      "/contact",
      "/mode",
      "/MBA-MSC-Digital-Marketing-Abroad",
      "/workshop",
      "/blog",
      "/certificate",
      "/privacy-policy",
      "/terms-and-conditions",
      "/cookie-policy",
      "/website-disclaimer",
      "/refund-cancellation-policy"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "axios": "^1.12.2",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.548.0",
    "react": "^19.1.1",
    "react-country-flag": "^3.1.0",
    "react-dom": "^19.1.1",
    "react-google-recaptcha": "^3.1.0",
    "react-icons": "^5.5.0",
    "react-phone-input-2": "^2.15.1",
    "react-router-dom": "^7.9.1",
    "sonner": "^2.0.7",
    "swiper": "^12.0.3",
    "tailwindcss": "^4.1.13",
    "vite-plugin-static-copy": "^3.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "react-snap": "^1.23.0",
    "vite": "^7.1.6",
    "vite-plugin-prerender": "^1.0.8"
  }
}
